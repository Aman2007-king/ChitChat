rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - avatar: string (required)
    //   - status: string
    //   - phoneNumber: string
    //   - lastSeen: timestamp
    //   - isAI: bool
    //   - personality: string
    //   - privacy: map
    //
    // Collection: chats/{chatId}/messages
    // Document ID: messageId
    // Fields:
    //   - id: string (required)
    //   - chatId: string (required)
    //   - senderId: string (required)
    //   - text: string
    //   - audioUrl: string
    //   - type: string (required, enum: text, audio)
    //   - timestamp: timestamp (required)
    //   - status: string (required, enum: sent, delivered, read)
    //   - reactions: map
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ry650506@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'avatar']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.avatar is string && data.avatar.size() < 1000;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'chatId', 'senderId', 'type', 'timestamp', 'status']) &&
             data.id is string &&
             data.chatId is string &&
             data.senderId is string &&
             data.type in ['text', 'audio'] &&
             data.timestamp is timestamp &&
             data.status in ['sent', 'delivered', 'read'];
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data)) || isAdmin();
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMessage(request.resource.data) && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() && (
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reactions'])) ||
        isAdmin()
      );
    }
  }
}
